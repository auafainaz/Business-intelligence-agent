APP_ENV=local
PUBLIC_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
DATABASE_PATH=backend/data/clientiq.sqlite3
LOCAL_CALL_OUTPUT_DIR=backend/outputs/calls
GROK_VOICE_PROMPT_PATH=backend/prompts/grok-voice-system-prompt.md
SAVE_DASHBOARD_SCHEMA_PATH=docs/tool-schemas/save_dashboard_data.json
XAI_REALTIME_MODEL=grok-voice-think-fast-1.0
XAI_REALTIME_VOICE=ara

# Provider credentials: set real values only in backend/.env, never in this example file.
XAI_API_KEY=
XAI_REALTIME_URL=wss://api.x.ai/v1/realtime
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
GMAIL_FROM_EMAIL=
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
DELIVERY_ENABLED=true
